{
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://192.168.64.1:11434",
        "apiKey": "ollama-local",
        "api": "ollama",
        "models": [
          {
            "id": "qwen3:30b",
            "name": "Qwen3 30B",
            "contextWindow": 32768
          }
        ]
      }
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/qwen3:30b"
      },
      "contextTokens": 32768,
      "memorySearch": {
        "enabled": true,
        "provider": "openai",
        "model": "nomic-embed-text",
        "remote": {
          "baseUrl": "http://192.168.64.1:11434/v1/",
          "apiKey": "ollama-local"
        },
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3,
            "candidateMultiplier": 4
          }
        },
        "store": {
          "path": "~/.openclaw/memory/{agentId}.sqlite"
        }
      },
      "compaction": {
        "mode": "safeguard",
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 4000
        }
      }
    },

    "list": []
  },

  "skills": {
    "allowBundled": []
  },

  "gateway": {
    "mode": "local",
    "bind": "loopback",
    "port": __PORT__
  }
}
